# Copy to `.env` in this folder. Never commit `.env`.

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=defectra

# --- JWT ---
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- vLLM (OpenAI-compatible server; NOT FastAPI) ---
VLLM_BASE_URL=http://127.0.0.1:8000
VLLM_MODEL=your-model-name
VLLM_API_KEY=
VLLM_TEMPERATURE=0.3
VLLM_MAX_TOKENS=20000
VLLM_HTTP_TIMEOUT_S=300

# --- Backend tuning ---
INSPECTION_CHAT_TEMPERATURE=0.35
INSPECTION_MAX_IMAGE_MB=20
LANDING_ASSISTANT_TEMPERATURE=0.42

# --- Frontend (Vite) — proxy /api to Defectra uvicorn ---
VITE_API_PROXY_TARGET=http://127.0.0.1:8010
# VITE_API_BASE_URL=
VITE_CHAT_SCROLL_NEAR_BOTTOM_PX=100

# --- Inspection chat PDF (Puppeteer + Chromium via Node) ---
INSPECTION_PDF_RENDER_TIMEOUT_S=120
