{
  "buildCommand": "node ./node_modules/vite/bin/vite.js build",
  "rewrites": [
    { "source": "/dashboard/image-analysis", "destination": "/dashboard/image-analysis/index.html" },
    { "source": "/dashboard/image-analysis/", "destination": "/dashboard/image-analysis/index.html" },
    { "source": "/dashboard/live", "destination": "/dashboard/live/index.html" },
    { "source": "/dashboard/live/", "destination": "/dashboard/live/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
    }
  ]
}
